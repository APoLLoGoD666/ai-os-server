# APEX AI OS — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# ── REQUIRED (system fails without these) ────────────────────────
ANTHROPIC_API_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
APP_ACCESS_KEY=
JWT_SECRET=
DASHBOARD_PASSWORD=
DATABASE_URL=

# ── REQUIRED FOR INTEGRATIONS ─────────────────────────────────────
NOTION_API_KEY=
SLACK_BOT_TOKEN=
GOOGLE_API_KEY=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
DEEPGRAM_API_KEY=
GITHUB_TOKEN=
OBSIDIAN_API_KEY=
OBSIDIAN_URL=

# ── OPERATIONAL (deployment and orchestration) ────────────────────
CRON_SECRET=
RENDER_API_KEY=
RENDER_SERVICE_ID=
RENDER_EXTERNAL_URL=
RENDER_HEALTH_URL=
AUTONOMY_LEVEL=3
PORT=3000

# ── FEATURE FLAGS ─────────────────────────────────────────────────
COGNITIVE_CRONS_ENABLED=true
LOCAL_MODE=

# ── RAG SIDECAR (deploy apex-ai-sidecar on Render, then set URL) ──
RAG_SIDECAR_URL=
# Also set OPENAI_API_KEY on the sidecar service for vector embeddings

# ── OPTIONAL (enhanced features) ──────────────────────────────────
OPENAI_API_KEY=
OPENROUTER_API_KEY=
VOYAGE_API_KEY=
BRAVE_API_KEY=
ELEVENLABS_API_KEY=
SENTRY_DSN=
ANTHROPIC_MODEL=
SUPABASE_ANON_KEY=
SUPABASE_ACCESS_TOKEN=
AGENT_SECRET=

# ── HOLDOUT EVALUATION (second Supabase project, Founder-only) ────
SUPABASE_HOLDOUT_URL=
SUPABASE_HOLDOUT_ANON_KEY=
HOLDOUT_EVAL_KEY=
HOLDOUT_ORACLE_URL=

# ── LOCAL / DEVELOPMENT ONLY ──────────────────────────────────────
OBSIDIAN_VAULT_PATH=
LOG_LEVEL=
PIPELINE_BUDGET_USD=
