# APEX AI OS — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# ── REQUIRED (system fails without these) ────────────────────────
ANTHROPIC_API_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
APP_ACCESS_KEY=
JWT_SECRET=
DASHBOARD_PASSWORD=

# ── REQUIRED FOR INTEGRATIONS ─────────────────────────────────────
NOTION_API_KEY=
SLACK_BOT_TOKEN=
GOOGLE_API_KEY=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
OBSIDIAN_API_KEY=
GITHUB_TOKEN=

# ── OPERATIONAL (deployment and orchestration) ────────────────────
CRON_SECRET=
RENDER_API_KEY=
RENDER_SERVICE_ID=
RENDER_EXTERNAL_URL=
RAG_SIDECAR_URL=
AUTONOMY_LEVEL=

# ── OPTIONAL (enhanced features) ──────────────────────────────────
AGENT_SECRET=
OPENROUTER_API_KEY=
SENTRY_DSN=
ANTHROPIC_MODEL=
SUPABASE_ANON_KEY=
VOYAGE_API_KEY=
BRAVE_API_KEY=

# ── LOCAL / DEVELOPMENT ONLY ──────────────────────────────────────
OBSIDIAN_URL=
OBSIDIAN_VAULT_PATH=
LOCAL_MODE=
LOG_LEVEL=
PIPELINE_BUDGET_USD=
RENDER_HEALTH_URL=
